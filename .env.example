# Database
ConnectionStrings__LedgerlyDb=Host=localhost;Port=5432;Database=ledgerly;Username=ledgerly;Password=YOUR_DB_PASSWORD

# JWT (API)
Jwt__Secret=YOUR_SECRET_MIN_32_CHARS_RANDOM_STRING_HERE
Jwt__Issuer=Ledgerly
Jwt__Audience=LedgerlyUsers
Jwt__ExpiryHours=24

# SendGrid (API)
SendGrid__ApiKey=SG.your-sendgrid-api-key
SendGrid__FromEmail=noreply@yourdomain.com

# CORS — allow Blazor Web frontend (API)
Cors__AllowedOrigins=https://your-web.railway.app

# Web frontend base URL (API — used for email confirmation/reset links)
Web__BaseUrl=https://your-web.railway.app

# API base URL (Web)
Api__BaseUrl=https://your-api.railway.app
