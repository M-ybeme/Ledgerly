@page "/debts"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using Ledgerly.Contracts.Debts
@inject Ledgerly.Web.Services.DebtAccountsApiClient Api
@inject NotificationService NotificationService

<PageTitle>Debts — Ledgerly</PageTitle>

<RadzenText TextStyle="TextStyle.H4">Debt Accounts</RadzenText>

<RadzenCard class="rz-mb-4">
    <RadzenText TextStyle="TextStyle.H6" class="rz-mb-3">@(editingId.HasValue ? "Edit Debt" : "Add Debt")</RadzenText>
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.End" Gap="1rem" Wrap="FlexWrap.Wrap">
        <div>
            <RadzenLabel Text="Name" />
            <RadzenTextBox @bind-Value="formName" Placeholder="e.g. Chase Visa" Style="display:block; width:200px;" />
        </div>
        <div>
            <RadzenLabel Text="Balance ($)" />
            <RadzenNumeric @bind-Value="formBalance" Min="0m" Step="0.01m" Format="F2" Style="display:block; width:130px;" />
        </div>
        <div>
            <RadzenLabel Text="Annual Rate (%)" />
            <RadzenNumeric @bind-Value="formRatePercent" Min="0.01m" Max="100m" Step="0.01m" Format="F2" Style="display:block; width:120px;" />
        </div>
        <div>
            <RadzenLabel Text="Min Payment ($)" />
            <RadzenNumeric @bind-Value="formMinPayment" Min="0.01m" Step="0.01m" Format="F2" Style="display:block; width:130px;" />
        </div>
        <RadzenButton Text="@(editingId.HasValue ? "Update" : "Add Debt")" Icon="@(editingId.HasValue ? "save" : "add")" ButtonStyle="ButtonStyle.Primary" Click="@Save" />
        @if (editingId.HasValue)
        {
            <RadzenButton Text="Cancel" Icon="cancel" ButtonStyle="ButtonStyle.Light" Click="@CancelEdit" />
        }
    </RadzenStack>
</RadzenCard>

@if (debts is null)
{
    <RadzenText>Loading…</RadzenText>
}
else if (debts.Count == 0)
{
    <RadzenAlert AlertStyle="AlertStyle.Info" AllowClose="false">No debt accounts yet. Add one above.</RadzenAlert>
}
else
{
    <RadzenDataGrid Data="@debts" TItem="DebtAccountDto" AllowSorting="true" AllowColumnResize="true">
        <Columns>
            <RadzenDataGridColumn TItem="DebtAccountDto" Property="Name" Title="Name" />
            <RadzenDataGridColumn TItem="DebtAccountDto" Title="Balance" Property="Balance">
                <Template Context="d">@d.Balance.ToString("C")</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="DebtAccountDto" Title="Annual Rate">
                <Template Context="d">@((d.AnnualInterestRate * 100).ToString("F2"))%</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="DebtAccountDto" Title="Min Payment" Property="MinimumPayment">
                <Template Context="d">@d.MinimumPayment.ToString("C")</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="DebtAccountDto" Title="Created">
                <Template Context="d">@d.CreatedUtc.ToString("yyyy-MM-dd")</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="DebtAccountDto" Title="Actions" Sortable="false" Width="120px">
                <Template Context="d">
                    <RadzenButton Icon="edit" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" Click="@(() => StartEdit(d))" class="rz-mr-1" />
                    <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Small" Click="@(() => Delete(d.Id))" />
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
}

@code {
    private List<DebtAccountDto>? debts;
    private string formName = "";
    private decimal formBalance;
    private decimal formRatePercent;
    private decimal formMinPayment;
    private Guid? editingId;

    protected override async Task OnInitializedAsync()
    {
        debts = await Api.GetAllAsync();
    }

    private async Task Save()
    {
        try
        {
            decimal annualRate = formRatePercent / 100m;

            if (editingId.HasValue)
            {
                var updated = await Api.UpdateAsync(editingId.Value,
                    new UpdateDebtAccountRequest(formName, formBalance, annualRate, formMinPayment));
                var idx = debts!.FindIndex(d => d.Id == editingId.Value);
                if (idx >= 0) debts[idx] = updated;
                NotificationService.Notify(NotificationSeverity.Success, "Updated", $"\"{updated.Name}\" saved.");
                CancelEdit();
            }
            else
            {
                var created = await Api.CreateAsync(
                    new CreateDebtAccountRequest(formName, formBalance, annualRate, formMinPayment));
                debts ??= [];
                debts.Add(created);
                NotificationService.Notify(NotificationSeverity.Success, "Created", $"\"{created.Name}\" added.");
                ResetForm();
            }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Error", ex.Message);
        }
    }

    private void StartEdit(DebtAccountDto d)
    {
        editingId = d.Id;
        formName = d.Name;
        formBalance = d.Balance;
        formRatePercent = d.AnnualInterestRate * 100m;
        formMinPayment = d.MinimumPayment;
    }

    private void CancelEdit()
    {
        editingId = null;
        ResetForm();
    }

    private void ResetForm()
    {
        formName = "";
        formBalance = 0;
        formRatePercent = 0;
        formMinPayment = 0;
    }

    private async Task Delete(Guid id)
    {
        try
        {
            await Api.DeleteAsync(id);
            debts?.RemoveAll(d => d.Id == id);
            NotificationService.Notify(NotificationSeverity.Success, "Deleted", "Debt account removed.");
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Error", ex.Message);
        }
    }
}
