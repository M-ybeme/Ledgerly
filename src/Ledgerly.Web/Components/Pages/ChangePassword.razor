@page "/change-password"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using Ledgerly.Contracts.Auth
@inject Ledgerly.Web.Services.AuthApiClient AuthApi
@inject NotificationService NotificationService

<PageTitle>Change Password — Ledgerly</PageTitle>

<RadzenText TextStyle="TextStyle.H4">Change Password</RadzenText>

<div style="max-width:400px; margin-top:1.5rem;">
    <RadzenCard>
        <div style="margin-bottom:1rem;">
            <RadzenLabel Text="Current Password" />
            <RadzenPassword @bind-Value="currentPassword" Style="display:block; width:100%;" />
        </div>
        <div style="margin-bottom:1rem;">
            <RadzenLabel Text="New Password" />
            <RadzenPassword @bind-Value="newPassword" Style="display:block; width:100%;" />
        </div>
        <div style="margin-bottom:0.75rem;">
            <RadzenLabel Text="Confirm New Password" />
            <RadzenPassword @bind-Value="confirmPassword" Style="display:block; width:100%;" />
        </div>
        <div style="margin-bottom:1.5rem; font-size:0.85em; color:var(--rz-text-secondary-color);">
            Minimum 8 characters, must include a digit.
        </div>

        <RadzenButton Text="Change Password" ButtonStyle="ButtonStyle.Primary" Click="@Submit" Disabled="@loading" />
    </RadzenCard>
</div>

@code {
    private string currentPassword = "";
    private string newPassword = "";
    private string confirmPassword = "";
    private bool loading;

    private async Task Submit()
    {
        if (newPassword != confirmPassword)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Error", "Passwords do not match.");
            return;
        }

        loading = true;
        try
        {
            await AuthApi.ChangePasswordAsync(new ChangePasswordRequest(currentPassword, newPassword));
            NotificationService.Notify(NotificationSeverity.Success, "Success", "Password changed successfully.");
            currentPassword = "";
            newPassword = "";
            confirmPassword = "";
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Error", ex.Message);
        }
        finally
        {
            loading = false;
        }
    }
}
