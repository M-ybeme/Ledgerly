@page "/reset-password"
@rendermode InteractiveServer
@using Ledgerly.Contracts.Auth
@inject Ledgerly.Web.Services.AuthApiClient AuthApi
@inject NavigationManager Nav

<PageTitle>Reset Password — Ledgerly</PageTitle>

<div style="max-width:400px; margin:80px auto;">
    <RadzenCard>
        <RadzenText TextStyle="TextStyle.H5" style="margin-bottom:1.5rem;">Set New Password</RadzenText>

        @if (success)
        {
            <RadzenAlert AlertStyle="AlertStyle.Success" ShowIcon="false" style="margin-bottom:1rem;">
                Your password has been reset. You can now log in with your new password.
            </RadzenAlert>
            <RadzenButton Text="Go to Login" ButtonStyle="ButtonStyle.Primary" Style="width:100%;" Click="@(() => Nav.NavigateTo("/login"))" />
        }
        else
        {
            @if (errorMessage is not null)
            {
                <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="false" style="margin-bottom:1rem;">@errorMessage</RadzenAlert>
            }

            <div style="margin-bottom:1rem;">
                <RadzenLabel Text="New Password" />
                <RadzenPassword @bind-Value="newPassword" Style="display:block; width:100%;" />
            </div>
            <div style="margin-bottom:0.75rem;">
                <RadzenLabel Text="Confirm New Password" />
                <RadzenPassword @bind-Value="confirmPassword" Style="display:block; width:100%;" />
            </div>
            <div style="margin-bottom:1.5rem; font-size:0.85em; color:var(--rz-text-secondary-color);">
                Minimum 8 characters, must include a digit.
            </div>

            <RadzenButton Text="Reset Password" ButtonStyle="ButtonStyle.Primary" Style="width:100%;" Click="@Submit" Disabled="@loading" />
        }
    </RadzenCard>
</div>

@code {
    [SupplyParameterFromQuery] public string? Email { get; set; }
    [SupplyParameterFromQuery] public string? Token { get; set; }

    private string newPassword = "";
    private string confirmPassword = "";
    private string? errorMessage;
    private bool loading;
    private bool success;

    private async Task Submit()
    {
        if (newPassword != confirmPassword)
        {
            errorMessage = "Passwords do not match.";
            return;
        }
        if (string.IsNullOrWhiteSpace(Email) || string.IsNullOrWhiteSpace(Token))
        {
            errorMessage = "Invalid reset link.";
            return;
        }

        errorMessage = null;
        loading = true;
        try
        {
            await AuthApi.ResetPasswordAsync(new ResetPasswordRequest(Email, Token, newPassword));
            success = true;
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            loading = false;
        }
    }
}
