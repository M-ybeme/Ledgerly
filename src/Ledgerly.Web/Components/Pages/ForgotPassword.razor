@page "/forgot-password"
@rendermode InteractiveServer
@using Ledgerly.Contracts.Auth
@inject Ledgerly.Web.Services.AuthApiClient AuthApi

<PageTitle>Forgot Password — Ledgerly</PageTitle>

<div style="max-width:400px; margin:80px auto;">
    <RadzenCard>
        <RadzenText TextStyle="TextStyle.H5" style="margin-bottom:1.5rem;">Reset Your Password</RadzenText>

        @if (sent)
        {
            <RadzenAlert AlertStyle="AlertStyle.Success" ShowIcon="false">
                If that email address is registered, a password reset link has been sent. Please check your inbox.
            </RadzenAlert>
        }
        else
        {
            @if (errorMessage is not null)
            {
                <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="false" style="margin-bottom:1rem;">@errorMessage</RadzenAlert>
            }

            <div style="margin-bottom:1.5rem;">
                <RadzenLabel Text="Email Address" />
                <RadzenTextBox @bind-Value="email" Placeholder="@emailPlaceholder" Style="display:block; width:100%;" />
            </div>

            <RadzenButton Text="Send Reset Link" ButtonStyle="ButtonStyle.Primary" Style="width:100%;" Click="@Submit" Disabled="@loading" />
        }

        <div style="margin-top:1rem; text-align:center; font-size:0.9em;">
            <a href="/login">Back to Login</a>
        </div>
    </RadzenCard>
</div>

@code {
    private readonly string emailPlaceholder = "you@example.com";
    private string email = "";
    private string? errorMessage;
    private bool loading;
    private bool sent;

    private async Task Submit()
    {
        errorMessage = null;
        loading = true;
        try
        {
            await AuthApi.ForgotPasswordAsync(new ForgotPasswordRequest(email));
            sent = true;
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            loading = false;
        }
    }
}
